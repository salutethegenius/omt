# Public site URL used for canonical tags, sitemap, and Open Graph URLs.
NEXT_PUBLIC_SITE_URL=https://orlandomaxtax.com

# Resend — booking form emails (domain must be verified in Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Orlando MaxTax <bookings@orlandomaxtax.com>
RESEND_TO_EMAIL=orlandomaxtax@gmail.com
# Set to false to skip the auto-reply sent to the person who submitted the form
RESEND_SEND_CONFIRMATION=true

# Optional webhook for CRM/automation alongside Resend
REQUEST_CALL_WEBHOOK_URL=
